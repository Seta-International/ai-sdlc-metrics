{
  "name": "future",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "agents/*",
    "data-platform/*",
    "packages/*"
  ],
  "scripts": {
    "prepare": "lefthook install",
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e",
    "db:generate": "bun run --cwd packages/db generate",
    "db:migrate": "bun run --cwd packages/db migrate",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "eslint": "^10.2.0",
    "future": "^2.3.1",
    "jiti": "^2.6.1",
    "lefthook": "^2.1.5",
    "prettier": "^3.8.2",
    "turbo": "^2.9.4",
    "typescript": "^6.0.2"
  }
}
