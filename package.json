{
  "name": "future",
  "private": true,
  "packageManager": "bun@1.3.12",
  "workspaces": [
    "apps/*",
    "data-platform/*",
    "packages/*"
  ],
  "scripts": {
    "prepare": "lefthook install",
    "setup": "sh scripts/setup.sh",
    "setup:full": "sh scripts/setup.sh --full",
    "setup:clean": "sh scripts/setup.sh --clean",
    "dev": "turbo dev",
    "build": "turbo build",
    "db:up": "docker compose -f docker-compose.local.yml up -d postgres redis",
    "db:down": "docker compose -f docker-compose.local.yml down",
    "db:logs": "docker compose -f docker-compose.local.yml logs -f postgres",
    "db:generate": "bun run --cwd packages/db generate",
    "db:migrate": "bun run --cwd packages/db migrate",
    "db:seed": "bun run --cwd apps/api seed",
    "tenant:provision": "bun run apps/api/scripts/provision-tenant.ts",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write --cache .",
    "format:check": "prettier --check --cache .",
    "test:unit": "turbo test:unit",
    "test:integration": "turbo test:integration",
    "test:e2e": "turbo test:e2e",
    "deps:outdated": "sh scripts/deps-workspaces.sh outdated",
    "deps:update": "sh scripts/deps-workspaces.sh update",
    "deps:update:interactive": "sh scripts/deps-workspaces.sh update:interactive",
    "deps:update:latest": "sh scripts/deps-workspaces.sh update:latest"
  },
  "devDependencies": {
    "eslint": "^10.2.1",
    "future": "^2.3.1",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.2",
    "lefthook": "^2.1.6",
    "prettier": "^3.8.3",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "@opentelemetry/api": "1.9.1"
  }
}
