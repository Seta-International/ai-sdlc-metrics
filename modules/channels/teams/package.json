{
  "name": "@seta/ms-teams",
  "version": "0.1.0",
  "description": "Microsoft Teams / Bot Framework channel adapter (hand-rolled)",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test:unit": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build:manifest": "tsx src/manifest/build.ts"
  },
  "license": "Apache-2.0",
  "type": "module",
  "types": "./dist/index.d.ts",
  "private": true,
  "files": [
    "dist"
  ],
  "dependencies": {
    "@opentelemetry/api": "1.9.1",
    "@seta/agent-core": "workspace:*",
    "@seta/agent-memory": "workspace:*",
    "@seta/agent-server": "workspace:*",
    "@seta/agent-workflows": "workspace:*",
    "@seta/middleware": "workspace:*",
    "@seta/oauth": "workspace:*",
    "@seta/observability": "workspace:*",
    "@seta/tenancy": "workspace:*",
    "adm-zip": "0.5.17",
    "hono": "4.12.18",
    "jose": "6.2.3",
    "lru-cache": "11.3.6",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@seta/tsconfig": "workspace:*",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^25.7.0",
    "msw": "2.7.0",
    "postgres": "3.4.9",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  }
}
