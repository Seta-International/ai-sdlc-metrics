NEXT_PUBLIC_MICROSOFT_TENANT_ID=
MICROSOFT_REDIRECT_URI=http://localhost:3000/auth/callback/microsoft

# Future platform tenant UUID for this deployment
NEXT_PUBLIC_TENANT_ID=
