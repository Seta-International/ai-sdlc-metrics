NEXT_PUBLIC_API_URL=http://localhost:4000
API_BASE_URL=http://localhost:4000

# Local dev only — enables instant email login without magic link email
# NEXT_PUBLIC_LOCAL_DEV=true

# Microsoft Entra SSO — OAuth callback URL registered on the IdP app
NEXT_PUBLIC_MICROSOFT_REDIRECT_URI=http://localhost:3000/auth/callback/microsoft

# Google Workspace SSO — OAuth callback URL registered on the IdP app
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback/google
