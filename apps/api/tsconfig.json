{
  "extends": "@future/tsconfig/base.json",
  "compilerOptions": {
    "moduleResolution": "nodenext",
    "module": "nodenext",
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "declarationMap": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "types": ["vitest/globals"]
  },
  "include": ["src"],
  "exclude": ["src/**/*.spec.ts", "src/**/*.integration.spec.ts", "src/**/*.type-test.ts"]
}
