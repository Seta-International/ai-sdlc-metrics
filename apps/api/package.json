    "@nestjs/core": "^11.1.19",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-fastify": "^11.1.19",
    "@trpc/server": "^11.16.0",
