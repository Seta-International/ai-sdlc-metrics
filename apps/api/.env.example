DATABASE_URL=postgresql://future:future@localhost:5432/future
PORT=4000
REDIS_URL=redis://localhost:6379
JWT_SECRET=local-dev-secret-change-in-production

# AI (agents module) — optional for local dev; agents are disabled when not set
# OPENAI_API_KEY=

# Local dev only — enables identity.devLogin tRPC procedure (never set in production)
LOCAL_DEV=1

# S3 (documents module)
S3_BUCKET=future-documents-local
S3_REGION=ap-southeast-1

# Platform admin bootstrap — set this to seed a platform_admin account via `bun run seed`
# FUTURE_PLATFORM_ADMIN_EMAIL=admin@your-domain.com

# Microsoft Entra SSO seed (optional — seeds the IdP provider for the system tenant)
# ENTRA_CLIENT_ID=your-entra-app-client-id
# ENTRA_TENANT_ID=your-entra-directory-tenant-id
# ENTRA_CLIENT_SECRET_REF=secrets/your-entra-client-secret-name   # AWS Secrets Manager key, not the raw secret
