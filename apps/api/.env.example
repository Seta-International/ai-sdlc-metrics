NODE_ENV=development
PORT=8080
DATABASE_URL=postgres://seta:dev@localhost:5432/seta
PUBLIC_BASE_URL=http://localhost:8080

ENTRA_CLIENT_ID=<azure-app-client-id>
ENTRA_CLIENT_SECRET=<azure-app-client-secret>

KMS_PROVIDER=env
DEV_DEK_BASE64=<base64-encoded-32-byte-key>
# AWS_REGION=us-east-1
# KMS_KEY_ARN=arn:aws:kms:...

# Generate with: openssl rand -hex 32
CONTINUATION_HMAC_KEY=<hex-64-chars>

PLANNER_CACHE_TTL_TASKS_SEC=60
PLANNER_CACHE_TTL_PLANS_SEC=600
PLANNER_CACHE_TTL_BUCKETS_SEC=300
PLANNER_CACHE_STALE_FALLBACK_MAX_SEC=3600
PLANNER_BATCH_CONCURRENCY=3
CONTINUATION_TTL_MIN=15

MS_BOT_ID=<microsoft-bot-app-id>
MS_BOT_SECRET=<microsoft-bot-password>
TEAMS_SKIP_JWT_VERIFY=false
PLANNER_SYNC_INTERVAL_MS=180000

OPENAI_EMBEDDING_MODEL=text-embedding-3-small
AGENT_EMBEDDINGS_PROVIDER=none

# LLM adapter keys — omit any provider you don't use
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_API_VERSION=2024-10-21