DATABASE_URL=postgresql://future:future@localhost:5432/future
PORT=4000
REDIS_URL=redis://localhost:6379
JWT_SECRET=local-dev-secret-change-in-production

# AI (agents module) — optional for local dev; agents are disabled when not set
# OPENAI_API_KEY=

# Local dev only — enables identity.devLogin tRPC procedure (never set in production)
LOCAL_DEV=1

# S3 (documents module)
S3_BUCKET=future-documents-local
S3_REGION=ap-southeast-1
