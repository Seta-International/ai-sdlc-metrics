NODE_ENV=development

# ── Core ──────────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://seta:dev@localhost:5432/seta
PORT=8080
PUBLIC_BASE_URL=http://localhost:8080

# ── Entra OAuth (bootstrap tenant's Graph app) ───────────────────────────────
# Bootstrap (first) tenant's Entra app for Graph (Planner / Directory / Mail).
# Additional tenants onboard via admin UI → per-tenant token vault, not .env.
ENTRA_CLIENT_ID=<azure-app-client-id>
ENTRA_CLIENT_SECRET=<azure-app-client-secret>

# ── Session + crypto ──────────────────────────────────────────────────────────
# openssl rand -base64 32
SESSION_HMAC_KEY=<base64-32-byte-secret>
SESSION_TTL_SEC=86400
KMS_PROVIDER=env
# openssl rand -base64 32
DEV_DEK_BASE64=<base64-encoded-32-byte-key>
# openssl rand -hex 32
CONTINUATION_HMAC_KEY=<hex-64-chars>
CONTINUATION_TTL_MIN=15
# AWS_REGION=us-east-1
# KMS_KEY_ARN=arn:aws:kms:...

# ── LLM adapter keys (omit any provider you don't use) ────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_API_VERSION=2024-10-21

# ── Planner ───────────────────────────────────────────────────────────────────
PLANNER_CACHE_TTL_TASKS_SEC=60
PLANNER_CACHE_TTL_PLANS_SEC=600
PLANNER_CACHE_TTL_BUCKETS_SEC=300
PLANNER_CACHE_STALE_FALLBACK_MAX_SEC=3600
PLANNER_BATCH_CONCURRENCY=3
PLANNER_SYNC_INTERVAL_MS=180000

# ── Teams bot ─────────────────────────────────────────────────────────────────
MS_BOT_ID=<microsoft-bot-app-id>
MS_BOT_SECRET=<microsoft-bot-password>
MS_BOT_TENANT_ID=<microsoft-bot-tenant-id>
TEAMS_SKIP_JWT_VERIFY=false

# ── Embeddings ────────────────────────────────────────────────────────────────
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
AGENT_EMBEDDINGS_PROVIDER=none

# ── Apps ──────────────────────────────────────────────────────────────────────
# Comma-separated list of SPAs the API treats as live (drives the `/me`
# AppSwitcher state). Each SPA is mounted at /<name>/ via the API reverse-proxy.
APPS_DEPLOYED=studio,console

# ── Bootstrap seed (writes the first tenant + its SSO config) ─────────────────
# First email in BOOTSTRAP_SUPERADMIN_EMAILS becomes the tenant owner.
# The bootstrap tenant gets its own per-tenant SSO Entra app (separate from
# the connector app above). See docs/QUICKSTART.md → "First-time SSO setup".
BOOTSTRAP_TENANT_SLUG=acme
BOOTSTRAP_TENANT_NAME=Acme Corp
BOOTSTRAP_ENTRA_DIRECTORY_ID=<entra-directory-id>
BOOTSTRAP_SSO_CLIENT_ID=<sso-app-client-id>
BOOTSTRAP_SSO_CLIENT_SECRET=<sso-app-client-secret>
# Comma-separated email domains that should resolve to this tenant at /sso/discover.
BOOTSTRAP_SSO_EMAIL_DOMAINS=your-tenant.onmicrosoft.com
BOOTSTRAP_CONNECTORS=ms365-planner,ms365-directory
# Set BOOTSTRAP_OFFLINE=1 to skip the live MSAL token acquisition during seed.
BOOTSTRAP_OFFLINE=1
BOOTSTRAP_SUPERADMIN_EMAILS=<admin@your-tenant.onmicrosoft.com>[,additional@example.com,...]

# ── Mailer (per-tenant; the bootstrap tenant gets a Graph mailer row) ─────────
# Graph mailer reuses the platform connector Entra app (Mail.Send admin-consented).
# Mailbox UPN/user id in the customer's M365 directory whose Outlook sends the mail.
BOOTSTRAP_MAILER_PROVIDER=graph
BOOTSTRAP_GRAPH_MAILBOX_USER_ID=no-reply@your-tenant.onmicrosoft.com
BOOTSTRAP_GRAPH_FROM_ADDRESS=no-reply@your-tenant.onmicrosoft.com
# Process-level fallback when a tenant has no mailer row (non-prod console mailer only).
MAILER_FROM_ADDRESS_DEFAULT=no-reply@your-tenant.onmicrosoft.com
