# Database
# `bun run db:up` creates `future`, `future_dev`, and `future_test`.
DATABASE_URL=postgresql://future:future@localhost:5432/future_dev
TEST_DATABASE_URL=postgresql://future:future@localhost:5432/future_test

# API
PORT=4000

# Auth (Microsoft Entra)
ENTRA_TENANT_ID=your-entra-tenant-id
ENTRA_CLIENT_ID=your-entra-client-id

# JWT Session
JWT_SECRET=change-me-to-a-random-32-byte-string

# Web zones
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXTAUTH_URL=http://localhost:3000

# Dev/test identity bootstrap (never set in production)
NEXT_PUBLIC_DEV_TENANT_ID=tenant-dev-local
NEXT_PUBLIC_DEV_ACTOR_ID=actor-dev-local
