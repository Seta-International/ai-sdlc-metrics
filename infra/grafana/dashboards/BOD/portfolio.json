    {
      "type": "stat",
      "title": "AI Net $ (portfolio, latest month)",
      "datasource": {
        "type": "postgres",
        "uid": "reporting-postgres"
      },
      "gridPos": {
        "x": 4,
        "y": 1,
        "w": 5,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "reporting-postgres"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT sum(w.ai_time_saved_h * CASE w.project WHEN 'Future' THEN 25 WHEN 'TeacherZone' THEN 25 ELSE 0 END) - sum(COALESCE(t.value::numeric, 0)) FROM (SELECT DISTINCT ON (project) * FROM reporting.metrics_wide WHERE period_type = 'month' AND ai_time_saved_h IS NOT NULL ORDER BY project, period_key DESC) w LEFT JOIN reporting.manual_inputs t ON t.project = w.project AND t.period_key = w.period_key AND t.field = 'ai_tool_cost_monthly'",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#d03b3b",
                "value": null
              },
              {
                "color": "#0ca30c",
                "value": 0
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "graphMode": "none",
        "colorMode": "value",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "description": "Hours saved \u00d7 per-project blended rate \u2212 tool costs."
    },
