          "rawSql": "SELECT r.period_start AS time, round(avg(r.rework_pct),1) AS \"Rework %\", round(avg(r.ai_pr_pct),1) AS \"AI PR %\" FROM (SELECT * FROM reporting.v_metrics WHERE period_type='month' UNION ALL SELECT * FROM reporting.v_metrics_q) r WHERE r.period_type = '$granularity' AND r.project IN ($project) AND $__timeFilter(r.period_start) GROUP BY r.period_start ORDER BY r.period_start",
          "refId": "A"
        }
      ],
