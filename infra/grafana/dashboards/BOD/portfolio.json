    {
      "type": "stat",
      "title": "Cumulative AI Net $ (to date)",
      "datasource": {
        "type": "postgres",
        "uid": "reporting-postgres"
      },
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 8,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#d03b3b",
                "value": null
              },
              {
                "color": "#0ca30c",
                "value": 0
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "graphMode": "none",
        "colorMode": "value",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "reporting-postgres"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT sum(cum_hours_saved * rate - cum_tool_cost) FROM (SELECT DISTINCT ON (v.project) v.*, CASE v.project WHEN 'Future' THEN 12 WHEN 'TeacherZone' THEN 12 ELSE 0 END AS rate FROM reporting.v_portfolio_roi v WHERE v.project IN ($project) AND $__timeFilter(v.period_start) ORDER BY v.project, v.period_start DESC) x",
          "refId": "A"
        }
      ],
      "description": "\u03a3 over selected projects of (cumulative AI hours saved \u00d7 blended rate) \u2212 cumulative AI tool cost. Green once net-positive (payback)."
    },
    {
      "type": "stat",
      "title": "Capacity unlocked (engineer-equiv)",
      "datasource": {
        "type": "postgres",
        "uid": "reporting-postgres"
      },
      "gridPos": {
        "x": 8,
        "y": 12,
        "w": 8,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "text",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "graphMode": "none",
        "colorMode": "value",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "reporting-postgres"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT round(sum(cum_hours_saved) / (40.0 * 4 * GREATEST(count(DISTINCT date_trunc('month', period_start)),1)), 1) FROM (SELECT v.* FROM reporting.v_portfolio_roi v WHERE v.project IN ($project) AND $__timeFilter(v.period_start)) v",
          "refId": "A"
        }
      ],
      "description": "Cumulative hours saved expressed as full-time engineers of extra capacity (\u2248160 h/engineer-month), no headcount added."
    },
    {
      "type": "timeseries",
      "title": "Spend vs Return ($, cumulative)",
      "datasource": {
        "type": "postgres",
        "uid": "reporting-postgres"
      },
      "gridPos": {
        "x": 16,
        "y": 12,
        "w": 8,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "text",
                "value": null
              }
            ]
          },
          "custom": {
            "showPoints": "always",
            "pointSize": 6,
            "lineWidth": 2,
            "fillOpacity": 14,
            "gradientMode": "opacity",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max",
            "lastNotNull"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "reporting-postgres"
          },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT v.period_start AS time, sum(v.cum_hours_saved * CASE v.project WHEN 'Future' THEN 12 WHEN 'TeacherZone' THEN 12 ELSE 0 END) AS \"Value\", sum(v.cum_tool_cost) AS \"Cost\" FROM reporting.v_portfolio_roi v WHERE v.project IN ($project) AND $__timeFilter(v.period_start) GROUP BY v.period_start ORDER BY v.period_start",
          "refId": "A"
        }
      ],
      "description": "Cumulative value vs cumulative cost; the gap is running net ROI."
    },
