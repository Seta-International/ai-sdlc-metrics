                "value": null
              }
            ]
          },
          "custom": {
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Project"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Open project board",
                    "targetBlank": false,
                    "url": "/d/ai-sdlc-${__data.fields.Project}"
                  }
                ]
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "reporting-postgres"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT project AS \"Project\", severity AS \"Severity\", reason AS \"Why\" FROM reporting.v_attention WHERE project IN ($project) ORDER BY severity DESC, project",
          "refId": "A"
        }
      ],
      "description": "The only per-project detail on this board. Click a project to drill into its operational dashboard."
    },
    {
      "type": "row",
