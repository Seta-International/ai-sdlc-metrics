    {
      "type": "stat",
      "title": "Cost Improvement (portfolio)",
      "datasource": {
        "type": "postgres",
        "uid": "reporting-postgres"
      },
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 5,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "reporting-postgres"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT round(avg(100 * (b.v - a.v) / NULLIF(b.v, 0)), 0) FROM (SELECT project, period_key, value::numeric v FROM reporting.manual_inputs WHERE field = 'cost_baseline') b JOIN (SELECT project, period_key, value::numeric v FROM reporting.manual_inputs WHERE field = 'cost_actual') a USING (project, period_key) JOIN (SELECT project, max(period_key) mk FROM reporting.manual_inputs WHERE field = 'cost_actual' GROUP BY project) m ON m.project = b.project AND m.mk = b.period_key",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "text",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "graphMode": "none",
        "colorMode": "value",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "description": "Baseline vs actual cost per unit, latest manual input per project."
    },
