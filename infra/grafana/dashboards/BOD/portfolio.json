      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "reporting-postgres"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT g.label AS \"Gate\", count(*) FILTER (WHERE mi.value='Yes') AS \"Met\", count(*) AS \"Projects\" FROM (SELECT DISTINCT ON (project) project, period_key FROM reporting.manual_inputs WHERE period_key LIKE '%-Q%' ORDER BY project, period_key DESC) q JOIN reporting.manual_inputs mi USING (project, period_key) JOIN (VALUES ('g2_ai_policy','AI policy'),('g3_required_review','Required human review'),('g6_security_controls','Security controls'),('g7_traceability','Traceability/audit'),('g8_model_governance','Model governance')) g(field,label) ON g.field = mi.field WHERE mi.project IN ($project) GROUP BY g.label ORDER BY 2",
          "refId": "A"
        }
      ],
      "description": "Governance posture from quarterly flags: how many selected projects meet each gate. Gaps are risk-oversight items."
    },
