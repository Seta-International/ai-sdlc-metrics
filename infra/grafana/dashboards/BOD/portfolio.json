    {
      "type": "table",
      "title": "Governance gates (projects meeting each)",
      "datasource": {
        "type": "postgres",
        "uid": "reporting-postgres"
      },
      "gridPos": {
        "x": 8,
        "y": 17,
        "w": 16,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "text",
                "value": null
              }
            ]
          },
          "custom": {
            "filterable": true
          }
        },
        "overrides": []
