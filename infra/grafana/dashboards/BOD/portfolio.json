      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "reporting-postgres"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT project AS \"Project\", period_key AS \"Sprint\", total_tasks AS \"Tasks\", total_prs AS \"PRs\", round(ai_pr_pct, 1) AS \"AI PR %\", round(agent_task_pct, 1) AS \"Agent Task %\", round(lead_time_h, 1) AS \"Lead Time h\", round(deploys_per_week, 2) AS \"Deploys/wk\", round(cfr_pct, 1) AS \"CFR %\", round(mttr_h, 1) AS \"MTTR h\", round(ai_pr_review_pct, 1) AS \"Review %\", round(rework_pct, 1) AS \"Rework %\", security_alerts AS \"Alerts\", round(autonomy_pct, 1) AS \"Autonomy %\", round(predictability_pct, 1) AS \"Predictability %\", CASE project WHEN 'Future' THEN (CASE WHEN (COALESCE(ai_tasks, 0) > 0 OR COALESCE(ai_prs, 0) > 0) AND (COALESCE(usage_rate_pct, 0) >= 50 AND COALESCE(ai_pr_pct, 0) >= 30) AND (COALESCE(agent_pr_pct, 0) >= 10 AND (COALESCE(ai_pr_review_pct, 0) >= 80 AND COALESCE(ai_pr_test_pct, 0) >= 50)) AND (COALESCE(autonomy_pct, 0) >= 50 AND (COALESCE(ai_pr_review_pct, 0) >= 80 AND COALESCE(ai_pr_test_pct, 0) >= 50)) THEN 4 WHEN (COALESCE(ai_tasks, 0) > 0 OR COALESCE(ai_prs, 0) > 0) AND (COALESCE(usage_rate_pct, 0) >= 50 AND COALESCE(ai_pr_pct, 0) >= 30) AND (COALESCE(agent_pr_pct, 0) >= 10 AND (COALESCE(ai_pr_review_pct, 0) >= 80 AND COALESCE(ai_pr_test_pct, 0) >= 50)) THEN 3 WHEN (COALESCE(ai_tasks, 0) > 0 OR COALESCE(ai_prs, 0) > 0) AND (COALESCE(usage_rate_pct, 0) >= 50 AND COALESCE(ai_pr_pct, 0) >= 30) THEN 2 WHEN (COALESCE(ai_tasks, 0) > 0 OR COALESCE(ai_prs, 0) > 0) THEN 1 ELSE 0 END) WHEN 'TeacherZone' THEN (CASE WHEN (COALESCE(ai_tasks, 0) > 0 OR COALESCE(ai_prs, 0) > 0) AND (COALESCE(usage_rate_pct, 0) >= 50 AND COALESCE(ai_pr_pct, 0) >= 30) AND (COALESCE(agent_pr_pct, 0) >= 10 AND (COALESCE(ai_pr_review_pct, 0) >= 80 AND COALESCE(ai_pr_test_pct, 0) >= 50)) AND (COALESCE(autonomy_pct, 0) >= 50 AND (COALESCE(ai_pr_review_pct, 0) >= 80 AND COALESCE(ai_pr_test_pct, 0) >= 50)) THEN 4 WHEN (COALESCE(ai_tasks, 0) > 0 OR COALESCE(ai_prs, 0) > 0) AND (COALESCE(usage_rate_pct, 0) >= 50 AND COALESCE(ai_pr_pct, 0) >= 30) AND (COALESCE(agent_pr_pct, 0) >= 10 AND (COALESCE(ai_pr_review_pct, 0) >= 80 AND COALESCE(ai_pr_test_pct, 0) >= 50)) THEN 3 WHEN (COALESCE(ai_tasks, 0) > 0 OR COALESCE(ai_prs, 0) > 0) AND (COALESCE(usage_rate_pct, 0) >= 50 AND COALESCE(ai_pr_pct, 0) >= 30) THEN 2 WHEN (COALESCE(ai_tasks, 0) > 0 OR COALESCE(ai_prs, 0) > 0) THEN 1 ELSE 0 END) END AS \"Stage\" FROM reporting.metrics_ratios r WHERE period_type = 'sprint' AND period_start = (SELECT max(period_start) FROM reporting.metrics_ratios r2 WHERE r2.project = r.project AND r2.period_type = 'sprint') ORDER BY project",
          "refId": "A"
        }
      ],
