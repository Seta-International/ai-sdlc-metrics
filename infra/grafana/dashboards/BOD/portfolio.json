          "text": "quarter",
          "value": "quarter"
        },
        "options": [
          {
            "text": "month",
            "value": "month",
            "selected": false
          },
          {
            "text": "quarter",
            "value": "quarter",
            "selected": true
          }
        ]
      },
      {
        "name": "project",
        "type": "query",
        "datasource": {
          "type": "postgres",
          "uid": "reporting-postgres"
        },
        "label": "Project",
        "multi": true,
        "includeAll": true,
        "refresh": 2,
        "sort": 1,
        "query": "SELECT DISTINCT project FROM reporting.v_metrics ORDER BY project",
        "current": {},
        "options": []
      }
    ]
  },
  "links": [
    {
      "type": "link",
      "title": "Download Excel (all projects)",
      "icon": "doc",
      "targetBlank": true,
      "url": "https://ai-metrics.seta-international.com/export.xlsx?project=all"
    }
  ],
  "panels": [
    {
      "type": "row",
      "title": "Decisions & Attention",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "type": "table",
      "title": "Needs a decision this period",
      "datasource": {
        "type": "postgres",
        "uid": "reporting-postgres"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 24,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "text",
                "value": null
              }
            ]
          },
          "custom": {
            "filterable": true
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "reporting-postgres"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT reason AS \"Item\", count(*) AS \"Projects\" FROM reporting.v_attention WHERE project IN ($project) AND severity >= 2 GROUP BY reason ORDER BY max(severity) DESC, 2 DESC LIMIT 3",
          "refId": "A"
        }
      ],
      "description": "Auto-generated from reporting.v_attention: the highest-severity board items (gate at Level 1, overall Level 1). Empty = no action required this period."
    },
    {
      "type": "table",
      "title": "Projects to act on",
      "datasource": {
        "type": "postgres",
        "uid": "reporting-postgres"
      },
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 6
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
