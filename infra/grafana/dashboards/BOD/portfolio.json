  "panels": [
    {
      "type": "row",
      "title": "Portfolio Scorecard \u2014 Latest Sprint per Project",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "type": "table",
      "title": "Latest Sprint Overview",
      "datasource": {
        "type": "postgres",
        "uid": "reporting-postgres"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "reporting-postgres"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT project, period_key AS sprint, round(ai_pr_pct, 1) AS \"AI PR %\", round(lead_time_h, 1) AS \"Lead time h\", round(deploys_per_week, 2) AS \"Deploys/wk\", round(cfr_pct, 1) AS \"CFR %\", round(mttr_h, 1) AS \"MTTR h\", round(autonomy_pct, 1) AS \"Autonomy %\", security_alerts AS \"Alerts\" FROM reporting.metrics_ratios r WHERE period_type = 'sprint' AND period_start = (SELECT max(period_start) FROM reporting.metrics_ratios r2 WHERE r2.project = r.project AND r2.period_type = 'sprint') ORDER BY project",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      },
      "options": {}
    },
