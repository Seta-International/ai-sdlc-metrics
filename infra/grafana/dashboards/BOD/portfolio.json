{
  "uid": "ai-sdlc-bod",
  "title": "AI SDLC \u2014 Portfolio (BOD)",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "timezone": "utc",
  "time": {
    "from": "now-180d",
