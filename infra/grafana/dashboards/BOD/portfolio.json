    {
      "type": "timeseries",
      "title": "AI PR % by Sprint",
      "datasource": {
        "type": "postgres",
        "uid": "reporting-postgres"
      },
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "reporting-postgres"
          },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT period_start AS time, project, ai_pr_pct FROM reporting.metrics_ratios WHERE period_type = 'sprint' ORDER BY period_start",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "text",
                "value": null
              }
            ]
          },
          "custom": {
            "showPoints": "always",
            "pointSize": 6
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Future"
            },
            "properties": [
              {
