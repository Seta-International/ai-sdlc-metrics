{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "LLM observability: latency (tok/s, TTFT, E2E) + GPU resources (VRAM, utilization, KV cache)",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 10,
      "title": "Latency",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "System-wide output token throughput: total generation tokens per second across all concurrent requests.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8, "spanNulls": false },
          "unit": "short",
          "displayName": "${__series.name}"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "legend": {
          "calcs": ["mean", "max", "lastNotNull"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (model_name) (rate(vllm:generation_tokens_total{model_name=~\"$vllm_model\"}[$__rate_interval]))",
          "legendFormat": "{{model_name}}",
          "refId": "A"
        }
      ],
      "title": "Tok/s (Output Throughput)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "System-wide input token throughput: total prompt tokens per second ingested by vLLM.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8, "spanNulls": false },
          "unit": "short",
          "displayName": "${__series.name}"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 1 },
      "id": 7,
      "options": {
        "legend": {
          "calcs": ["mean", "max", "lastNotNull"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (model_name) (rate(vllm:prompt_tokens_total{model_name=~\"$vllm_model\"}[$__rate_interval]))",
          "legendFormat": "{{model_name}}",
          "refId": "A"
        }
      ],
      "title": "Tok/s (Input Throughput)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Time to first output token. App-layer (agent_llm) includes network; vLLM layer is pure inference.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8, "spanNulls": false },
          "unit": "s",
          "displayName": "${__series.name}"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 10 },
      "id": 2,
      "options": {
        "legend": {
          "calcs": ["mean", "max", "lastNotNull"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.50, sum by (le, tenant, model) (rate(agent_llm_ttft_seconds_bucket{tenant=~\"$tenant\",model=~\"$model\"}[$__rate_interval])))",
          "legendFormat": "[app] p50 — {{tenant}} / {{model}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum by (le, tenant, model) (rate(agent_llm_ttft_seconds_bucket{tenant=~\"$tenant\",model=~\"$model\"}[$__rate_interval])))",
          "legendFormat": "[app] p95 — {{tenant}} / {{model}}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.50, sum by (le, model_name) (rate(vllm:time_to_first_token_seconds_bucket{model_name=~\"$vllm_model\"}[$__rate_interval])))",
          "legendFormat": "[vllm] p50 — {{model_name}}",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum by (le, model_name) (rate(vllm:time_to_first_token_seconds_bucket{model_name=~\"$vllm_model\"}[$__rate_interval])))",
          "legendFormat": "[vllm] p95 — {{model_name}}",
          "refId": "D"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, sum by (le, model_name) (rate(vllm:time_to_first_token_seconds_bucket{model_name=~\"$vllm_model\"}[$__rate_interval])))",
          "legendFormat": "[vllm] p99 — {{model_name}}",
          "refId": "E"
        }
      ],
      "title": "TTFT (Time to First Token)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "End-to-end request latency at the vLLM inference layer (queue + prefill + decode).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8, "spanNulls": false },
          "unit": "s",
          "displayName": "${__series.name}"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 10 },
      "id": 3,
      "options": {
        "legend": {
          "calcs": ["mean", "max", "lastNotNull"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.50, sum by (le, model_name) (rate(vllm:e2e_request_latency_seconds_bucket{model_name=~\"$vllm_model\"}[$__rate_interval])))",
          "legendFormat": "p50 — {{model_name}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum by (le, model_name) (rate(vllm:e2e_request_latency_seconds_bucket{model_name=~\"$vllm_model\"}[$__rate_interval])))",
          "legendFormat": "p95 — {{model_name}}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, sum by (le, model_name) (rate(vllm:e2e_request_latency_seconds_bucket{model_name=~\"$vllm_model\"}[$__rate_interval])))",
          "legendFormat": "p99 — {{model_name}}",
          "refId": "C"
        }
      ],
      "title": "E2E Latency per Request",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 },
      "id": 11,
      "title": "Resources",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "GPU framebuffer (VRAM) used per physical GPU, from DCGM exporter.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "spanNulls": false },
          "unit": "decmbytes",
          "displayName": "${__series.name}"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 8, "x": 0, "y": 20 },
      "id": 4,
      "options": {
        "legend": {
          "calcs": ["mean", "max", "lastNotNull"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "DCGM_FI_DEV_FB_USED",
          "legendFormat": "Used — GPU{{gpu}} ({{modelName}})",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "DCGM_FI_DEV_FB_USED + DCGM_FI_DEV_FB_FREE",
          "legendFormat": "Total — GPU{{gpu}} ({{modelName}})",
          "refId": "B"
        }
      ],
      "title": "VRAM Usage (MiB)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "GPU SM utilization per physical GPU, from DCGM exporter.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8, "spanNulls": false },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "displayName": "${__series.name}"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 8, "x": 8, "y": 20 },
      "id": 5,
      "options": {
        "legend": {
          "calcs": ["mean", "max", "lastNotNull"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "DCGM_FI_DEV_GPU_UTIL",
          "legendFormat": "GPU{{gpu}} — {{modelName}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "DCGM_FI_DEV_MEM_COPY_UTIL",
          "legendFormat": "Mem Copy — GPU{{gpu}}",
          "refId": "B"
        }
      ],
      "title": "GPU Utilization (%)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "vLLM KV cache occupancy. High values → near-OOM or evictions; low → underutilized.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 20, "spanNulls": false },
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "displayName": "${__series.name}",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 20 },
      "id": 6,
      "options": {
        "legend": {
          "calcs": ["mean", "max", "lastNotNull"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "vllm:kv_cache_usage_perc{model_name=~\"$vllm_model\"}",
          "legendFormat": "KV Cache — {{model_name}}",
          "refId": "A"
        }
      ],
      "title": "vLLM KV Cache Usage (%)",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["llm", "agent", "vllm", "gpu", "seta"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(agent_llm_output_tokens_total, tenant)",
        "hide": 0,
        "includeAll": true,
        "allValue": ".+",
        "label": "Tenant",
        "multi": true,
        "name": "tenant",
        "query": {
          "query": "label_values(agent_llm_output_tokens_total, tenant)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(agent_llm_output_tokens_total, model)",
        "hide": 0,
        "includeAll": true,
        "allValue": ".+",
        "label": "Model (agent)",
        "multi": true,
        "name": "model",
        "query": {
          "query": "label_values(agent_llm_output_tokens_total, model)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(vllm:e2e_request_latency_seconds_count, model_name)",
        "hide": 0,
        "includeAll": true,
        "allValue": ".+",
        "label": "Model (vLLM)",
        "multi": true,
        "name": "vllm_model",
        "query": {
          "query": "label_values(vllm:e2e_request_latency_seconds_count, model_name)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "LLM Metrics — Latency & Resources",
  "uid": "llm-metrics",
  "version": 1
}
