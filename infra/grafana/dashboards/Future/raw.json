        "showHeader": true,
        "cellHeight": "sm"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "reporting-postgres"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT * FROM reporting.v_metrics WHERE project = 'Future' ORDER BY period_type, period_start DESC",
          "refId": "A"
        }
      ],
      "description": "The v_metrics view: one row per period, every metric pivoted into columns plus the computed ratios."
    },
    {
      "type": "row",
