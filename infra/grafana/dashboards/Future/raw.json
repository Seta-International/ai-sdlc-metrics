          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT period_key AS \"Period\", field AS \"Field\", value AS \"Value\", entered_by AS \"By\", entered_at AS \"Entered\" FROM reporting.manual_inputs WHERE project = 'Future' ORDER BY period_key DESC, field",
