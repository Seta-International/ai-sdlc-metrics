  "panels": [
    {
      "type": "row",
      "title": "Raw Metrics: all collected values",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "type": "table",
      "title": "All Collected Metrics",
      "datasource": {
        "type": "postgres",
        "uid": "reporting-postgres"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 24,
        "h": 12
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "text",
                "value": null
              }
            ]
          },
          "custom": {
            "filterable": true
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "reporting-postgres"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT period_type AS \"Type\", period_key AS \"Period\", metric_key AS \"Metric\", value AS \"Value\", period_start AS \"From\", period_end AS \"To\", collected_at AS \"Collected\" FROM reporting.metric_counts WHERE project = 'Future' ORDER BY period_start DESC, period_type, metric_key",
          "refId": "A"
        }
      ],
      "description": "Every raw metric value the collector wrote (reporting.metric_counts), newest period first: the unaggregated source behind every dashboard panel."
    },
    {
      "type": "row",
      "title": "Derived Values (views)",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 13,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "type": "table",
      "title": "Derived Values (wide + ratios)",
      "datasource": {
        "type": "postgres",
        "uid": "reporting-postgres"
      },
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 24,
        "h": 10
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "text",
                "value": null
              }
            ]
          },
          "custom": {
            "filterable": true
