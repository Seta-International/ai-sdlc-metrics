        {
          "rawSql": "SELECT a2_pr_ai_ratio * 100 FROM reporting.ai_sprint_metrics WHERE project = '$project' AND sprint_label = '$sprint'",
          "format": "table"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 40 },
              { "color": "green", "value": 60 }
            ]
          }
        }
