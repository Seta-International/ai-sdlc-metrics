{
  "title": "AI SDLC — Team",
  "uid": "ai-sdlc-team",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5m",
  "tags": ["ai-sdlc", "team"],
  "time": { "from": "now-30d", "to": "now" },
  "timezone": "browser",
  "templating": {
    "list": [
      {
        "name": "project",
        "type": "query",
        "datasource": { "type": "postgres", "uid": "reporting-postgres" },
        "query": "SELECT DISTINCT project FROM reporting.ai_sprint_metrics ORDER BY 1",
        "refresh": 2,
        "includeAll": false,
        "hide": 0
      },
      {
        "name": "sprint",
        "type": "query",
        "datasource": { "type": "postgres", "uid": "reporting-postgres" },
        "query": "SELECT DISTINCT sprint_label FROM reporting.ai_sprint_metrics WHERE project = '$project' ORDER BY 1 DESC",
        "refresh": 2,
        "includeAll": false,
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Live Snapshot",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "A4 — AI Adoption %",
      "datasource": { "type": "postgres", "uid": "reporting-postgres" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "targets": [
        {
          "rawSql": "SELECT a4_ai_issue_ratio * 100 FROM reporting.ai_sprint_metrics WHERE project = '$project' AND sprint_label = '$sprint'",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 30 },
              { "color": "green", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "A2 — AI PR %",
      "datasource": { "type": "postgres", "uid": "reporting-postgres" },
