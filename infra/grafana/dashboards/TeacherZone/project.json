          "datasource": {
            "type": "postgres",
            "uid": "reporting-postgres"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT 100 * (b.v - a.v) / NULLIF(b.v, 0) FROM (SELECT period_key, value::numeric v FROM reporting.manual_inputs WHERE project = 'TeacherZone' AND field = 'cost_baseline') b JOIN (SELECT period_key, value::numeric v FROM reporting.manual_inputs WHERE project = 'TeacherZone' AND field = 'cost_actual') a USING (period_key) ORDER BY period_key DESC LIMIT 1",
