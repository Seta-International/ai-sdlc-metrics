{
  "name": "@seta/ms-graph",
  "version": "0.1.0",
  "description": "Microsoft Graph HTTP client",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test:unit": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "license": "Apache-2.0",
  "type": "module",
  "types": "./dist/index.d.ts",
  "private": true,
  "files": [
    "dist"
  ],
  "dependencies": {
    "@microsoft/microsoft-graph-types": "2.43.1",
    "@opentelemetry/api": "1.9.1",
    "@seta/audit": "workspace:*",
    "@seta/middleware": "workspace:*",
    "@seta/oauth": "workspace:*",
    "@seta/observability": "workspace:*",
    "@seta/tenant": "workspace:*",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@seta/tsconfig": "workspace:*",
    "@types/node": "^24.12.3",
    "msw": "2.7.0",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
