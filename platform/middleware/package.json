{
  "name": "@seta/middleware",
  "version": "0.1.0",
  "description": "Hono middleware: auth + tenant + errors + openapi + rate-limit",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test:unit": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "license": "Apache-2.0",
  "type": "module",
  "types": "./dist/index.d.ts",
  "private": true,
  "files": [
    "dist"
  ],
  "dependencies": {
    "@hono/node-server": "2.0.2",
    "@hono/zod-openapi": "1.4.0",
    "@seta/auth": "workspace:*",
    "@seta/observability": "workspace:*",
    "@seta/tenant": "workspace:*",
    "hono": "4.12.18",
    "hono-rate-limiter": "^0.5.3"
  },
  "devDependencies": {
    "@seta/tsconfig": "workspace:*",
    "@types/node": "^24.12.3",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
