{
  "name": "@seta/oauth",
  "version": "0.1.0",
  "description": "Generic OAuth 2.0 PKCE + OBO + encrypted token store",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test:unit": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "license": "Apache-2.0",
  "type": "module",
  "types": "./dist/index.d.ts",
  "private": true,
  "files": [
    "dist"
  ],
  "dependencies": {
    "@aws-sdk/client-kms": "3.1045.0",
    "@azure/msal-node": "5.2.0",
    "@seta/audit": "workspace:*",
    "@seta/connector-registry": "workspace:*",
    "@seta/db": "workspace:*",
    "@seta/middleware": "workspace:*",
    "@seta/tenant": "workspace:*",
    "dotenv": "17.4.2",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.18",
    "lru-cache": "11.3.6",
    "postgres": "3.4.9",
    "uuid": "14.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@seta/connector-ms365-directory": "workspace:*",
    "@seta/connector-ms365-planner": "workspace:*",
    "@seta/tsconfig": "workspace:*",
    "@types/node": "^24.12.3",
    "drizzle-kit": "0.31.10",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
