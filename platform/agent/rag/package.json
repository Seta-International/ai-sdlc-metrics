{
  "name": "@seta/agent-rag",
  "version": "0.1.0",
  "description": "Composition layer over chunking + embeddings + vector with RRF fusion",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts src/types.ts src/testkit.ts --format esm --dts --sourcemap",
    "dev": "tsup src/index.ts src/types.ts src/testkit.ts --format esm --dts --watch",
    "test:unit": "vitest run src/",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test:integration": "vitest run tests/"
  },
  "license": "Apache-2.0",
  "type": "module",
  "private": true,
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "dependencies": {
    "@seta/agent-chunking": "workspace:*",
    "@seta/agent-core": "workspace:*",
    "@seta/agent-embeddings": "workspace:*",
    "@seta/agent-vector": "workspace:*",
    "@seta/db": "workspace:*",
    "@seta/observability": "workspace:*",
    "@seta/tenancy": "workspace:*",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@seta/tsconfig": "workspace:*",
    "@types/node": "^25.8.0",
    "fast-check": "4.8.0",
    "postgres": "3.4.9",
    "tsup": "8.5.1",
    "typescript": "6.0.3"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./testkit": {
      "types": "./dist/testkit.d.ts",
      "import": "./dist/testkit.js"
    }
  }
}
