{
  "name": "@seta/agent-chunking",
  "version": "0.1.0",
  "description": "Token-bounded text chunker with char-offset preservation for RAG",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test:unit": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "license": "Apache-2.0",
  "type": "module",
  "private": true,
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "dependencies": {
    "@seta/agent-core": "workspace:*",
    "js-tiktoken": "1.0.21",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@seta/tsconfig": "workspace:*",
    "@types/node": "^24.12.3",
    "fast-check": "4.8.0",
    "tsup": "8.5.1",
    "typescript": "6.0.3"
  }
}
