{
  "name": "@seta/agent-core",
  "version": "0.1.0",
  "description": "Type-safe, framework-free agent kernel: messages + tools + model router + run loop + streaming",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts src/testkit/index.ts --format esm --dts --sourcemap",
    "dev": "tsup src/index.ts src/testkit/index.ts --format esm --dts --watch",
    "test:unit": "vitest run src/",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test:integration": "vitest run tests/"
  },
  "license": "Apache-2.0",
  "type": "module",
  "types": "./dist/index.d.ts",
  "private": true,
  "files": [
    "dist"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "0.95.2",
    "@opentelemetry/api": "1.9.1",
    "@seta/middleware": "workspace:*",
    "@seta/observability": "workspace:*",
    "@seta/tenancy": "workspace:*",
    "hono": "4.12.18",
    "js-tiktoken": "1.0.21",
    "msw": "2.14.6",
    "openai": "6.37.0",
    "uuid": "14.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@opentelemetry/sdk-trace-base": "2.7.1",
    "@opentelemetry/sdk-trace-node": "2.7.1",
    "@seta/tsconfig": "workspace:*",
    "@types/node": "^25.7.0",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./testkit": {
      "import": "./dist/testkit/index.js",
      "types": "./dist/testkit/index.d.ts"
    }
  }
}
