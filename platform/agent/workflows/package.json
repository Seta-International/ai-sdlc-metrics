{
  "name": "@seta/agent-workflows",
  "version": "0.1.0",
  "description": "Typed workflow DSL with in-memory runner; durable suspend/resume in W2",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test:unit": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test:integration": "vitest run -c vitest.integration.config.ts"
  },
  "license": "Apache-2.0",
  "type": "module",
  "private": true,
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "dependencies": {
    "@opentelemetry/api": "1.9.1",
    "@seta/agent-core": "workspace:*",
    "@seta/audit": "workspace:*",
    "@seta/db": "workspace:*",
    "@seta/middleware": "workspace:*",
    "@seta/observability": "workspace:*",
    "@seta/tenancy": "workspace:*",
    "drizzle-orm": "0.45.2",
    "p-queue": "9.2.0",
    "postgres": "3.4.9",
    "uuid": "14.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@seta/tsconfig": "workspace:*",
    "@types/node": "^25.7.0",
    "drizzle-kit": "0.31.10",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  }
}
