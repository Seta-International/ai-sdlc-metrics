{
  "name": "@seta/agent-memory",
  "version": "0.1.0",
  "description": "Memory persistence (threads, messages, working memory) for the agent kernel",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test:unit": "vitest run src/",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test:integration": "vitest run tests/"
  },
  "license": "Apache-2.0",
  "type": "module",
  "private": true,
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "dependencies": {
    "@seta/agent-core": "workspace:*",
    "@seta/audit": "workspace:*",
    "@seta/db": "workspace:*",
    "@seta/middleware": "workspace:*",
    "@seta/observability": "workspace:*",
    "@seta/tenant": "workspace:*",
    "drizzle-orm": "0.45.2",
    "js-tiktoken": "1.0.21",
    "postgres": "3.4.9",
    "uuid": "14.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@seta/tsconfig": "workspace:*",
    "@types/node": "^24.12.3",
    "dotenv": "17.4.2",
    "drizzle-kit": "0.31.10"
  }
}
